# ==========================================================
# PrepPal Server - Environment Variables
# ==========================================================
# Copy this file to .env and fill in your API keys
#
# 1. SERPER API KEY (for Google Search)
#    - Go to https://serper.dev
#    - Sign up (free, gives 2500 searches)
#    - Copy your API key below
#
# 2. GEMINI API KEY (for AI-powered Q&A extraction)
#    - Go to https://aistudio.google.com/apikey
#    - Sign in with Google account
#    - Create an API key (free tier: 15 requests/minute)
#    - Copy your API key below
# ==========================================================

SERPER_API_KEY=YOUR_SERPER_API_KEY
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
PORT=3001
